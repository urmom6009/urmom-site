---
import "../../styles/global.css";

const adminLinks = [
  {
    name: "uptime kuma dashboard",
    href: "https://kuma.urmom.systems",
    detail: "monitors, alerts, incidents, and status pages"
  },
  {
    name: "netdata live metrics",
    href: "https://netdata.urmom.systems",
    detail: "cpu, memory, disk, network, containers, and host telemetry"
  },
  {
    name: "cloudflare dashboard",
    href: "https://dash.cloudflare.com",
    detail: "dns, tunnels, access policies, pages deployments"
  },
  {
    name: "github repository",
    href: "https://github.com/urmom6009/urmom-site",
    detail: "source code and deployment history"
  }
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>admin systems | urmom.systems</title>
    <meta name="robots" content="noindex" />
  </head>

  <body class="min-h-screen bg-zinc-950 text-zinc-100 antialiased">
    <div class="pointer-events-none fixed inset-0 bg-[linear-gradient(to_right,#ffffff08_1px,transparent_1px),linear-gradient(to_bottom,#ffffff08_1px,transparent_1px)] bg-[size:48px_48px]"></div>
    <div class="pointer-events-none fixed inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(236,72,153,0.16),transparent_35%),radial-gradient(circle_at_70%_10%,rgba(96,165,250,0.13),transparent_35%)]"></div>

    <main class="relative mx-auto max-w-5xl px-6 py-10">
      <nav class="mb-20 flex items-center justify-between border-b border-white/10 pb-5">
        <a href="/" class="font-mono text-sm tracking-[0.22em] text-zinc-300">
          urmom.systems
        </a>

        <a href="/systems" class="font-mono text-sm text-zinc-400 hover:text-white">
          public systems
        </a>
      </nav>

      <section class="mb-14">
        <p class="mb-5 font-mono text-xs uppercase tracking-[0.3em] text-pink-300">
          authorized systems view
        </p>

        <h1 class="max-w-4xl text-5xl font-semibold tracking-[-0.04em] text-white md:text-7xl">
          private infrastructure control room.
        </h1>

        <p class="mt-7 max-w-3xl text-lg leading-8 text-zinc-400">
          this page should only be reachable after cloudflare access approves the request.
          if this page is visible without authentication, something has gone sideways
          and the little security goblin needs attention.
        </p>
      </section>

      <section class="grid gap-4 md:grid-cols-2">
        {adminLinks.map((item) => (
          <a
            href={item.href}
            class="group rounded-2xl border border-white/10 bg-white/[0.035] p-6 transition hover:-translate-y-1 hover:border-pink-300/30 hover:bg-white/[0.06]"
          >
            <p class="mb-4 font-mono text-xs uppercase tracking-[0.25em] text-pink-300">
              private
            </p>

            <div class="flex items-center justify-between gap-4">
              <h2 class="text-2xl font-semibold tracking-tight text-white">
                {item.name}
              </h2>

              <span class="font-mono text-sm text-zinc-500 group-hover:text-pink-300">
                open
              </span>
            </div>

            <p class="mt-4 leading-7 text-zinc-400">
              {item.detail}
            </p>
          </a>
        ))}
      </section>
    </main>
  </body>
</html>

---
import BaseLayout from "../../layouts/base.astro";
import PageIntro from "../../components/page-intro.astro";

const adminLinks = [
  {
    name: "uptime kuma dashboard",
    href: "https://kuma.urmom.systems",
    detail: "Monitors, alerts, incidents, and public status page controls.",
  },
  {
    name: "netdata live metrics",
    href: "https://netdata.urmom.systems",
    detail: "Host telemetry for CPU, memory, disk, network, containers, and processes.",
  },
  {
    name: "cloudflare dashboard",
    href: "https://dash.cloudflare.com",
    detail: "DNS, access policies, tunnel routing, Pages deployments, and security rules.",
  },
  {
    name: "github repository",
    href: "https://github.com/urmom6009/urmom-site",
    detail: "Source code, branch history, deploy configuration, and future PR workflow.",
  },
];
---

<BaseLayout
  title="admin systems · colin vargas"
  description="Private systems launchpad for authorized urmom.systems administration."
  active="systems"
>
  <Fragment slot="head">
    <meta name="robots" content="noindex" />
  </Fragment>

  <PageIntro
    eyebrow="admin / authorized systems"
    title="private infrastructure control room."
    description="This route is meant to sit behind Cloudflare Access. If it is visible without authentication, the access policy needs attention before adding more operational detail."
  />

  <section class="admin-grid">
    {adminLinks.map((item) => (
      <a class="admin-link surface-panel" href={item.href}>
        <p class="eyebrow">private</p>
        <h2>{item.name}</h2>
        <p>{item.detail}</p>
        <span class="text-link">open -></span>
      </a>
    ))}
  </section>
</BaseLayout>

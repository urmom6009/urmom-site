---
import "../styles/global.css";

const focusAreas = [
  {
    label: "research",
    title: "computational aerospace",
    text: "numerical methods, cfd, adaptive mesh refinement, combustion, and physical modeling."
  },
  {
    label: "systems",
    title: "personal infrastructure",
    text: "dns, tunnels, monitoring, linux servers, uptime, backups, and controlled chaos."
  },
  {
    label: "writing",
    title: "technical notes",
    text: "clean explanations of engineering, infrastructure, and things i had to suffer through at one point."
  }
  ];

const projects = [
  "amrex finite-volume solver - thesis",
  "homelab monitoring stack",
  "minecraft server infrastructure",
  "cantera propulsion studies"
];
---

<html lang="en">
	<head>
    <meta charset="utf-8" />
    <meta name= "viewport" content="width=device-width" />
    <title>colin vargas | urmom.systems</title>
    <meta 
      name="description"
      content="colin vargas: aerospace engineering, numerical methods, computational fluid dynamics, and personal infrastructure"
    />
  </head>

  <body class="min-h-screen bg-zinc-950 text-zinc-100 antialiased">
    <div class="pointer-events-none fixed inset-0 bg-[linear-gradient(to_right,#ffffff08_1px,transparent_1px),linear-gradient(to_bottom,#ffffff08_1px,transparent_1px)] bg-[size:48px_48px]"></div>
    <div class="pointer-events-none fixed inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(236,72,153,0.16),transparent_35%),radial-gradient(circle_at_70%_10%,rgba(96,165,250,0.13),transparent_35%)]"></div>

    <main class="relative mx-auto max-w-6x1 px-6 py-8 md:py-12">
      <nav class="mb-24 flex items-center justify-between border-b border-white/10 pb-5">
        <a href="/" class="font-mono text-sm tracking-[0.22em] text-zinc-300">
          urmom.systems
        </a>

        <div class="hidden gap-6 font-mono text-sm text-zinc-400 md:flex">
          <a href="/projects" class="hover:text-white">projects</a>
          <a href="/research" class="hover:text-white">research</a>
          <a href="/systems" class="hover:text-white">systems</a>
          <a href="/writing" class="hover:text-white">writing</a>
        </div>
      </nav>

      <section class="mb-24">
        <div class="mb-6 inline-flex rounded-full border border-pink-400/30 bg-pink-400/10 px-4 py-2 font-mono text-xs uppercase tracking-[0.25em] text-pink-300">
          colin vargas | aerospace engineering
        </div>

        <h1 class="max-w-5x1 text-5x1 font-semibold tracking-tight text-white md:text-7x1">
          aerospace engineering, numerical methods, and infractructure that mostly behaves.
        </h1>

        <p class="mt-8 max-w-2x1 text-lg leading-8 text-zinc-400">
          i'm building numerical tools for complex physical systems while also learning how to make infrastructure that is reliable and as ubiquitous as a certain joke.
        </p>

        <div class="mt-10 flex flex-wrap gap-4">
          <a 
            href="/projects"
            class="rounded-full bg-white px-5 py-3 text-sm font-semibold text-zinc-950 transition hover:bg-zinc-200"
           >
            view projects
           </a>
          
          <a
            href="/research"
            class="rounded-full border border-white/15 bg-white/15 px-5 py-3 text-sm font-semibold text-zinc-100 transition hover:border-white/30 hover:bg-white/10"
          >
            research direction & snippets
          </a>
        </div>
      </section>

      <section class="grid gap-8 rounded-3x1 border border-white/10 bg-zinc-900/60 p-6 md:grid-cols-[1fr_1.2fr] md:p-8">
        {focusAreas.map((item) => (
          <article class="rounded-3x1 border border-white/10 bg-white/[0.035] p-6 shadow-black/20 backdrop-blur">
            <p class="mb-4 font-mono text-xs uppercase tracking-[0.25em] text-pink-300">
              {item.label}
            </p>
            <h2 class="mb-3 text-2x1 font-semibold text-white">{item.title}</h2>
            <p class="leading-7 text-zinc-400">{item.text}</p>
          </article>
        ))}
      </section>

      <section class="grid gap-8 rounded-3x1 border border-white/10 bg-zinc-900/60 p-6 md:grid-cols-[1fr_1.2fr] md:p-8">
        <div>
          <p class="mb-4 font-mono text-xs uppercase tracking-[0.25em] text-blue-300">
            current build queue
          </p>
          <h2 class="text-3x1 font-semibold text-white">things worth clicking eventually</h2>
          <p class="mt-4 leading-7 text-zinc-400">
            the site is starting as a clean static portfolio. eventually, the goal is to turn it into a living technical record:
            research notes, project writeups, system diagrams, and incident logs.
          </p>
        </div>

        <div class="grid gap-3">
          {projects.map((project) => (
            <a 
              href="/projects"
              class="group rounded-2x1 border border-white/10 bg-black/20 p-5 transition hover:border-pink-300/40 hover:bg-white/[0.06]"
            >
              <div class="flex items-center justify-between gap-4">
                <span class="text-lg font-medium text-zinc-100">{project}</span>
                <span class="font-mono text-sm text-zinc-500 group-hover:text-pink-300">open</span>
              </div>
            </a>
            ))}
        </div>
      </section>

      <footer class="mt-20 border-t border-white/10 pt-6 font-mono text-sm text-zinc-500">
        built by colin vargas - computational aerospace | infrastructure | suspiciously effective domain choices
      </footer>
    </main>
  </body>
</html>

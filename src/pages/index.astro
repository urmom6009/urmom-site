---
const navItems = [
  { label: "projects", href: "/projects" },
  { label: "research", href: "/research" },
  { label: "systems", href: "/systems" },
  { label: "writing", href: "/writing" },
];

const cards = [
  {
    label: "research",
    title: "computational aerospace",
    description:
      "numerical methods, cfd, adaptive mesh refinement, combustion, and physical modeling.",
    href: "/research",
    cta: "explore research",
    tone: "pink",
    visual: "flow",
  },
  {
    label: "systems",
    title: "personal infrastructure",
    description:
      "dns, tunnels, monitoring, linux servers, uptime, backups, and controlled chaos.",
    href: "/systems",
    cta: "view systems",
    tone: "blue",
    visual: "servers",
  },
  {
    label: "writing",
    title: "technical notes",
    description:
      "clean explanations of engineering, infrastructure, and things i had to suffer through at one point.",
    href: "/writing",
    cta: "read writing",
    tone: "purple",
    visual: "notes",
  },
];

const buildItems = [
  {
    title: "amrex finite-volume solver - thesis",
    description:
      "adaptive finite-volume solver with block-structured amr, compressible flow, and mpi parallelization.",
    status: "in progress",
    href: "/projects/amrex-solver",
    tone: "pink",
    icon: "cube",
  },
  {
    title: "uptime kuma monitoring stack",
    description:
      "self-hosted monitoring, alerting, and status pages for public-facing systems.",
    status: "live",
    href: "/systems",
    tone: "green",
    icon: "cloud",
  },
  {
    title: "homelab node expansions",
    description: "more compute, more storage, more heat. because apparently that is the hobby.",
    status: "planned",
    href: "/projects/homelab",
    tone: "blue",
    icon: "server",
  },
];
---

<html lang="en">
  <head>
    <script is:inline>
      (() => {
        try {
          const savedTheme = localStorage.getItem("theme");
          const prefersLight = window.matchMedia("(prefers-color-scheme: light)").matches;
          const theme = savedTheme || (prefersLight ? "light" : "dark");

          document.documentElement.dataset.theme = theme;
        } catch {
          document.documetnElement.dataset.theme = "dark";
        }
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>urmom.systems</title>
    <meta
      name="description"
      content="personal site for aerospace engineering, numerical methods, infrastructure, and technical notes."
      />
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const button = document.querySelector("[data-theme-toggle]");
        const label = document.querySelector("[data-theme-label]");

        const setTheme = (theme) => {
          root.dataset.theme = theme;

          if (label) {
            label.textContent = theme;
          }

          if (button) {
            button.setAttribute("aria-label", `switch to ${theme === "light" ? "dark" : "light"} mode`);
          }
        };

        setTheme(root.dataset.theme || "dark");

        button?.addEventListener("click", () => {
          const nextTheme = root.dataset.theme === "light" ? "dark" : "light";
          setTheme(nextTheme);

          try {
            localStorage.setItem("theme", nextTheme);
          } catch {}
        });
      })();
    </script>
  </head>

  <body>
    <div class="page-shell">
      <div class="background-glow"></div>
      <div class="grid-overlay"></div>
      <header class="site-header">
        <a class="brand" href="/" aria-label="urmom.systems home">
          urmom.systems
        </a>

        <nav aria-label="primary navigation">
          {
            navItems.map((item) => (
              <a href={item.href}>{item.label}</a>
            ))
          }
        </nav>
      </header>

      <main>
        <section class="hero" aria-labelledby="hero-title">
          <p class="eyebrow">colin vargas | aerospace engineering</p>
          <h1 id="hero-title">engineering systems that mostly behave.</h1>
          <p class="hero-copy">
            aerospace engineering, numerical methods, and infrastructure that
            intersect at cfd, adaptive systems, and a personal flair that is
            reliable enough to survive contact with reality.
          </p>

          <div class="hero-actions">
            <a class="button primary" href="/projects">view projects</a>
            <a class="button secondary" href="/research">research direction</a>
          </div>
        </section>

        <section class="card-grid" aria-label="site sections">
          {
            cards.map((card) => (
              <a class={`feature-card ${card.tone}`} href={card.href}>
                <div>
                  <p class="section-label">{card.label}</p>
                  <h2>{card.title}</h2>
                  <p>{card.description}</p>
                </div>

                <span class="card-link">
                  <span aria-hidden="true">→</span>
                  {card.cta}
                </span>

                <span class={`card-visual ${card.visual}`} aria-hidden="true">
                  <span></span>
                  <span></span>
                  <span></span>
                </span>
              </a>
            ))
          }
        </section>

        <section class="lower-grid" aria-label="current work and system status">
          <aside class="queue-panel">
            <p class="section-label blue">current build queue</p>
            <h2>things worth clicking eventually</h2>

            <p>ongoing projects, experiments, and infrastructure that deserve to see the light of day.</p>

            <a class="status-card" href="/systems">
              <div class="status-topline">
                <span>
                  <span class="live-dot"></span>
                  public systems status
                </span>
                <strong>all systems nominal</strong>
              </div>
              <p>uptime kuma monitoring stack <span>online</span></p>
            </a>
            
          </aside>

          <section class="build-list" aria-label="featured work">
            {
              buildItems.map((item) => (
                <a class="build-item" href={item.href}>
                  <div class={`build-icon ${item.tone}`} aria-hidden="true">
                    {item.icon === "cube" && (
                      <svg viewBox="0 0 24 24">
                        <path d="M12 2 21 7v10l-9 5-9-5V7l9-5Z" />
                        <path d="m3 7 9 5 9-5" />
                        <path d="M12 12v10" />
                        <path d="m7.5 4.5 9 5" />
                        <path d="m16.5 4.5-9 5" />
                      </svg>
                    )}

                    {item.icon === "cloud" && (
                      <svg viewBox="0 0 24 24">
                        <path d="M7 18h10a4 4 0 0 0 .5-7.97A6 6 0 0 0 6.15 8.4 4.75 4.75 0 0 0 7 18Z" />
                      </svg>
                    )}

                    {item.icon === "server" && (
                      <svg viewBox="0 0 24 24">
                        <rect x="4" y="4" width="16" height="6" rx="1.5" />
                        <rect x="4" y="14" width="16" height="6" rx="1.5" />
                        <path d="M8 7h.01" />
                        <path d="M8 17h.01" />
                        <path d="M12 7h6" />
                        <path d="M12 17h6" />
                      </svg>
                    )}
                  </div>

                  <div class="build-copy">
                    <h3>{item.title}</h3>
                    <p>{item.description}</p>
                  </div>

                  <div class="build-meta">
                    <span class={`status-badge ${item.tone}`}>
                      {item.status}
                    </span>
                    <span class="chevron" aria-hidden="true">›</span>
                  </div>
                </a>
              ))
            }
          </section>
        </section>
      </main>
    </div>
  </body>
</html>

<style is:global>
  :root,
html[data-theme="dark"] {
  color-scheme: dark;

  --bg: #050608;
  --panel: rgba(18, 19, 24, 0.72);
  --panel-strong: rgba(20, 21, 27, 0.9);
  --border: rgba(255, 255, 255, 0.1);
  --border-strong: rgba(255, 255, 255, 0.16);
  --text: rgba(255, 255, 255, 0.94);
  --muted: rgba(255, 255, 255, 0.58);
  --faint: rgba(255, 255, 255, 0.36);

  --pink: #ff73b7;
  --blue: #74b9ff;
  --purple: #c77dff;
  --green: #5ff2a0;

  --glow-pink: rgba(255, 56, 146, 0.28);
  --glow-blue: rgba(48, 137, 255, 0.22);
  --glow-purple: rgba(139, 74, 255, 0.08);
  --grid-line: rgba(255, 255, 255, 0.055);
  --vignette: rgba(0, 0, 0, 0.44);

  --button-primary-bg: #ffffff;
  --button-primary-text: #08090d;
  --shadow: rgba(0, 0, 0, 0.26);
  --theme-icon-glow: rgba(255, 255, 255, 0.45);
}

html[data-theme="light"] {
  color-scheme: light;

  --bg: #f7f2ea;
  --panel: rgba(255, 255, 255, 0.66);
  --panel-strong: rgba(255, 255, 255, 0.88);
  --border: rgba(20, 24, 32, 0.12);
  --border-strong: rgba(20, 24, 32, 0.2);
  --text: rgba(16, 18, 24, 0.94);
  --muted: rgba(16, 18, 24, 0.62);
  --faint: rgba(16, 18, 24, 0.42);

  --pink: #c92f83;
  --blue: #2266d8;
  --purple: #7d3fc7;
  --green: #128b58;

  --glow-pink: rgba(255, 87, 170, 0.22);
  --glow-blue: rgba(59, 130, 246, 0.18);
  --glow-purple: rgba(125, 63, 199, 0.08);
  --grid-line: rgba(18, 24, 38, 0.075);
  --vignette: rgba(255, 255, 255, 0.28);

  --button-primary-bg: #111318;
  --button-primary-text: #ffffff;
  --shadow: rgba(18, 24, 38, 0.13);
  --theme-icon-glow: rgba(201, 47, 131, 0.35);
}
  * {
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
  }

  body {
    margin: 0;
    min-height: 100vh;
    background: var(--bg);
    color: var(--text);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .page-shell {
    position: relative;
    isolation: isolate;
    min-height: 100vh;
    overflow: hidden;
    padding: 3rem clamp(1.25rem, 4vw, 4rem) 4rem;
  }

  .background-glow {
  position: fixed;
  inset: 0;
  z-index: -3;
  background:
    radial-gradient(circle at 24% 18%, var(--glow-pink), transparent 34rem),
    radial-gradient(circle at 68% 12%, var(--glow-blue), transparent 36rem),
    radial-gradient(circle at 50% 70%, var(--glow-purple), transparent 36rem),
    var(--bg);
}

  .grid-overlay {
  position: fixed;
  inset: 0;
  z-index: -2;
  opacity: 0.42;
  background-image:
    linear-gradient(var(--grid-line) 1px, transparent 1px),
    linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
  background-size: 4rem 4rem;
  mask-image: linear-gradient(to bottom, black, black 70%, transparent);
}

 .page-shell::before {
  content: "";
  position: fixed;
  inset: 0;
  z-index: -1;
  background:
    linear-gradient(to bottom, transparent, var(--bg) 92%),
    radial-gradient(circle at center, transparent 0, var(--vignette) 100%);
  pointer-events: none;
}

  .site-header,
  main {
    width: min(100%, 1220px);
    margin-inline: auto;
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding-bottom: 1.4rem;
    border-bottom: 1px solid var(--border);
  }

  .brand {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.95rem;
    letter-spacing: 0.34em;
    color: rgba(255, 255, 255, 0.9);
  }

  .header-actions {
  display: flex;
  align-items: center;
  gap: clamp(1rem, 2.5vw, 2rem);
}

.theme-toggle {
  display: inline-flex;
  align-items: center;
  gap: 0.55rem;
  min-height: 2.2rem;
  padding: 0.35rem 0.72rem;
  border: 1px solid var(--border);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.045);
  color: var(--muted);
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  font-size: 0.78rem;
  text-transform: lowercase;
  cursor: pointer;
  transition:
    color 180ms ease,
    border-color 180ms ease,
    background 180ms ease,
    transform 180ms ease;
}

.theme-toggle:hover {
  color: var(--text);
  border-color: var(--border-strong);
  background: rgba(255, 255, 255, 0.075);
  transform: translateY(-1px);
}

.theme-toggle-icon {
  width: 0.62rem;
  height: 0.62rem;
  border-radius: 999px;
  background: var(--text);
  box-shadow: 0 0 1rem var(--theme-icon-glow);
}
  nav {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 2.5vw, 2rem);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.9rem;
    color: var(--muted);
  }

  nav a {
    position: relative;
    transition:
      color 180ms ease,
      opacity 180ms ease;
  }

  nav a:hover {
    color: var(--text);
  }

  nav a::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.55rem;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--blue), transparent);
    opacity: 0;
    transform: scaleX(0.5);
    transition:
      opacity 180ms ease,
      transform 180ms ease;
  }

  nav a:hover::after {
    opacity: 1;
    transform: scaleX(1);
  }

  .hero {
    max-width: 760px;
    padding-block: clamp(4.5rem, 11vw, 8.5rem) clamp(2rem, 5vw, 4rem);
  }

  .eyebrow,
  .section-label,
  .status-badge,
  .status-topline {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    text-transform: uppercase;
    letter-spacing: 0.28em;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    max-width: 100%;
    margin: 0 0 1.25rem;
    padding: 0.48rem 0.9rem;
    border: 1px solid rgba(255, 115, 183, 0.36);
    border-radius: 999px;
    background: rgba(255, 115, 183, 0.1);
    color: #ff9bc9;
    font-size: 0.75rem;
    box-shadow: 0 0 2rem rgba(255, 115, 183, 0.08);
  }

  h1,
  h2,
  h3,
  p {
    margin: 0;
  }

  h1 {
    max-width: 720px;
    font-size: clamp(3.5rem, 9vw, 7.5rem);
    line-height: 0.9;
    letter-spacing: -0.075em;
    text-wrap: balance;
  }

  .hero-copy {
    max-width: 650px;
    margin-top: 1.3rem;
    color: rgba(255, 255, 255, 0.68);
    font-size: clamp(1rem, 1.5vw, 1.14rem);
    line-height: 1.75;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1.7rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    padding-inline: 1.35rem;
    border-radius: 999px;
    font-weight: 700;
    font-size: 0.92rem;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease;
  }

  .button:hover {
    transform: translateY(-2px);
  }

  .button.primary {
  background: var(--button-primary-bg);
  color: var(--button-primary-text);
  box-shadow: 0 1rem 2rem var(--shadow);
}

  .button.secondary {
    border: 1px solid var(--border-strong);
    background: rgba(255, 255, 255, 0.045);
    color: rgba(255, 255, 255, 0.86);
  }

  .button.secondary:hover {
    border-color: rgba(255, 255, 255, 0.28);
    background: rgba(255, 255, 255, 0.075);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .feature-card,
  .queue-panel,
  .build-list {
    border: 1px solid var(--border);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.035), transparent),
      var(--panel);
      box-shadow:
  0 1rem 3rem var(--shadow),
  inset 0 1px 0 rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(18px);
  }

  .feature-card {
    position: relative;
    min-height: 14.25rem;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 2rem;
    padding: 1.55rem;
    border-radius: 1rem;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease;
  }

  .feature-card:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.2);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.055), transparent),
      rgba(21, 23, 30, 0.82);
  }

  .section-label {
    margin-bottom: 1rem;
    font-size: 0.78rem;
    font-weight: 700;
  }

  .pink .section-label,
  .section-label.pink {
    color: var(--pink);
  }

  .blue .section-label,
  .section-label.blue {
    color: var(--blue);
  }

  .purple .section-label,
  .section-label.purple {
    color: var(--purple);
  }

  .feature-card h2,
  .queue-panel h2 {
    font-size: 1.1rem;
    letter-spacing: -0.03em;
  }

  .feature-card p:not(.section-label),
  .queue-panel > p {
    margin-top: 0.8rem;
    color: var(--muted);
    line-height: 1.65;
  }

  .card-link {
    position: relative;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    color: rgba(255, 255, 255, 0.58);
    font-size: 0.92rem;
  }

  .pink .card-link span {
    color: var(--pink);
  }

  .blue .card-link span {
    color: var(--blue);
  }

  .purple .card-link span {
    color: var(--purple);
  }

  .card-visual {
    position: absolute;
    right: 1rem;
    bottom: 1rem;
    width: 9rem;
    height: 6rem;
    opacity: 0.28;
    pointer-events: none;
  }

  .card-visual.flow {
    border-radius: 50%;
    border: 1px solid rgba(255, 115, 183, 0.18);
    transform: skewX(-24deg) rotate(-8deg);
  }

  .card-visual.flow span {
    position: absolute;
    inset: calc(var(--i, 0) * 0.7rem);
    border: 1px solid rgba(255, 115, 183, 0.26);
    border-radius: 50%;
  }

  .card-visual.flow span:nth-child(1) {
    --i: 1;
  }

  .card-visual.flow span:nth-child(2) {
    --i: 2;
  }

  .card-visual.flow span:nth-child(3) {
    --i: 3;
  }

  .card-visual.servers,
  .card-visual.notes {
    display: grid;
    gap: 0.45rem;
    align-content: center;
  }

  .card-visual.servers span {
    height: 1.2rem;
    border: 1px solid rgba(116, 185, 255, 0.55);
    border-radius: 0.25rem;
    background:
      radial-gradient(circle at 88% 50%, var(--blue) 0 2px, transparent 3px),
      rgba(116, 185, 255, 0.04);
  }

  .card-visual.notes {
    width: 5rem;
    height: 6.4rem;
    border: 1px solid rgba(199, 125, 255, 0.5);
    border-radius: 0.35rem;
    padding: 1rem 0.8rem;
  }

  .card-visual.notes span {
    height: 1px;
    background: rgba(199, 125, 255, 0.65);
  }

  .lower-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.9fr;
    gap: 1rem;
    margin-top: 1rem;
  }

  .queue-panel,
  .build-list {
    border-radius: 1rem;
  }

  .queue-panel {
    padding: 1.55rem;
  }

  .status-card {
    display: block;
    margin-top: 1.6rem;
    padding: 1.1rem;
    border: 1px solid var(--border);
    border-radius: 0.8rem;
    background: rgba(255, 255, 255, 0.03);
    transition:
      transform 180ms ease,
      border-color 180ms ease;
  }

  .status-card:hover {
    transform: translateY(-2px);
    border-color: rgba(95, 242, 160, 0.28);
  }

  .status-topline {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    color: var(--muted);
    font-size: 0.68rem;
  }

  .status-topline span {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }

  .live-dot {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: var(--green);
    box-shadow: 0 0 1.25rem rgba(95, 242, 160, 0.7);
  }

  .status-topline strong {
    padding: 0.25rem 0.55rem;
    border: 1px solid rgba(95, 242, 160, 0.32);
    border-radius: 999px;
    color: var(--green);
    font-size: 0.62rem;
    font-weight: 700;
  }

  .status-card p {
    margin-top: 1.2rem;
    color: var(--muted);
  }

  .status-card p span {
    color: var(--green);
  }

  .build-list {
    overflow: hidden;
  }

  .build-item {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.35rem;
    min-height: 6.4rem;
    padding: 1rem 1.35rem;
    border-bottom: 1px solid var(--border);
    transition:
      background 180ms ease,
      transform 180ms ease;
  }

  .build-item:last-child {
    border-bottom: 0;
  }

  .build-item:hover {
    background: rgba(255, 255, 255, 0.045);
  }

  .build-icon {
    display: grid;
    place-items: center;
    width: 4rem;
    height: 4rem;
    border-radius: 0.8rem;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.035);
  }

  .build-icon svg {
    width: 2rem;
    height: 2rem;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .build-icon.pink {
    color: var(--pink);
    border-color: rgba(255, 115, 183, 0.32);
    background: rgba(255, 115, 183, 0.075);
  }

  .build-icon.blue {
    color: var(--blue);
    border-color: rgba(116, 185, 255, 0.32);
    background: rgba(116, 185, 255, 0.075);
  }

  .build-icon.green {
    color: var(--blue);
    border-color: rgba(116, 185, 255, 0.32);
    background: rgba(116, 185, 255, 0.075);
  }

  .build-copy h3 {
    font-size: clamp(1rem, 1.8vw, 1.35rem);
    letter-spacing: -0.035em;

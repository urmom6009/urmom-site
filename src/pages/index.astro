---
import BaseLayout from "../layouts/base.astro";

const directions = [
  {
    label: "research",
    title: "adaptive flow methods",
    href: "/research",
  },
  {
    label: "projects",
    title: "tools with receipts",
    href: "/projects",
  },
  {
    label: "systems",
    title: "infrastructure that admits it exists",
    href: "/systems",
  },
];

const fragments = [
  "finite volume",
  "propulsion",
  "AMR",
  "status pages",
  "linux",
  "technical notes",
  "verification",
  "cloudflare",
  "paraview",
];
---

<BaseLayout
  title="colin vargas · aerospace, compute, systems"
  description="Personal site for Colin Vargas: aerospace engineering, numerical methods, infrastructure, projects, and technical notes."
  active="home"
>
  <section class="home-editorial" aria-labelledby="home-title">
    <div class="home-editorial-copy">
      <p class="eyebrow">colin vargas / aerospace engineering</p>
      <h1 id="home-title">useful systems, built near the edge of chaos.</h1>
      <p>
        I work where computational aerospace, numerical methods, and personal
        infrastructure start arguing with each other. The goal is not to show
        everything at once. The goal is to make the signal sharp enough to follow.
      </p>

      <div class="button-row">
        <a class="button primary" href="/about">online resume</a>
        <a class="button ghost" href="/projects">selected work</a>
      </div>
    </div>

    <aside class="home-chaos-map" aria-label="working fragments">
      {fragments.map((fragment, index) => (
        <span style={`--i: ${index}`}>{fragment}</span>
      ))}
    </aside>
  </section>

  <section class="home-direction-band" aria-label="primary directions">
    {directions.map((item) => (
      <a href={item.href}>
        <span>{item.label}</span>
        <strong>{item.title}</strong>
      </a>
    ))}
  </section>

  <section class="home-statement">
    <p class="eyebrow">operating thesis</p>
    <h2>
      Build the solver, run the system, write down the weird part before it
      becomes folklore.
    </h2>
    <p>
      This site is a working surface for research direction, project notes,
      infrastructure, and the occasional technical explanation that made enough
      sense to survive being written down.
    </p>
  </section>
</BaseLayout>

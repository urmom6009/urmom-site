---
const projects = [
  "amrex finite-volume solver - thesis",
  "homelab monitoring stack",
  "minecraft paper server infrastructure",
  "cantera propulsion chemistry studies",
  "subaru wrx aero simulation experiments"
  ];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>projects | urmom.systems</title>
  </head>

  <body class="min-h-screen bg-zinc-950 px-6 py-16 text-zinc-100">
    <main class="mx-auto max-w-4x1">
      <a href="/" class="font-mono text-sm text-zinc-400">home</a>

      <h1 class="mt-10 text-5x1 font-semibold">projects</h1>

      <div class="mt-10 grid gap-4">
        {projects.map((project) => (
          <article class="rounded-2x1 border border-zinc-800 bg-zinc-950/50 p-6">
            <h2 class="text-2x1 font-semibold">{project}</h2>
            <p class="mt-3 text-zinc-400">
            write the problem, the technical decisions, what worked, and what i would improve/do next time.
            </p>
          </article>
        ))}
      </div>
    </main>
  </body>
</html>

---
import BaseLayout from "../layouts/base.astro";
---

<BaseLayout
  title="contact · colin vargas"
  description="contact colin vargas for research, engineering, infrastructure, and professional opportunities."
  active="contact"
>
  <section class="contact-screen" aria-labelledby="contact-title">
    <div class="contact-panel surface-panel">
      <p class="eyebrow">contact / direct line</p>
      <h1 id="contact-title">send the packet.</h1>
      <p>
        For research, engineering, infrastructure, teaching, or professional
        opportunities, email is the cleanest route.
      </p>

      <div class="contact-primary-actions">
        <a class="button primary" href="mailto:your-email@example.com">
          email me
        </a>
        <a class="button ghost" href="https://github.com/urmom6009">
          github
        </a>
        <a class="button ghost" href="https://www.linkedin.com/in/your-linkedin">
          linkedin
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from "../layouts/base.astro";
import PageIntro from "../components/page-intro.astro";

const featuredProjects = [
  {
    title: "adaptive cfd solver development",
    eyebrow: "research / numerical methods",
    status: "active",
    description:
      "building toward an amr-capable cfd solver stack for conservation-focused flow simulation, verification workflows, and propulsion-relevant physics.",
    stack: ["c++", "amrex", "finite volume", "paraview"],
    href: "/research",
  },
  {
    title: "urmom.systems infrastructure",
    eyebrow: "systems / homelab",
    status: "active",
    description:
      "public and private infrastructure for monitoring, dashboards, service routing, cloudflare tunnels, and server health visibility.",
    stack: ["linux", "docker", "cloudflare", "uptime kuma"],
    href: "/systems",
  },
  {
    title: "minecraft server operations",
    eyebrow: "ops / automation",
    status: "building",
    description:
      "paper server hosting with backups, update workflows, monitoring, access control, and the eventual dream of making server ops not feel like medieval plumbing.",
    stack: ["paper", "bash", "systemd", "backups"],
    href: "/systems",
  },
];

const smallerProjects = [
  {
    title: "coltex",
    label: "latex workflow tooling",
    description:
      "experiments in making technical writing and latex workflows faster, cleaner, and less cursed by default.",
  },
  {
    title: "planner system",
    label: "personal operating system",
    description:
      "task, habit, reflection, and workload-tracking experiments for turning chaos into something almost measurable.",
  },
  {
    title: "server monitoring bot",
    label: "telegram / status",
    description:
      "notification tooling for service failures, uptime checks, and the occasional message that says everything is on fire.",
  },
];
---

<BaseLayout
  title="projects · colin vargas"
  description="selected engineering, research, infrastructure, and tooling projects by colin vargas."
  active="projects"
>
  <PageIntro
    eyebrow="projects / active work"
    title="things i am building instead of sleeping normally."
    description="a curated view of research, infrastructure, tooling, and systems projects. some are polished, some are evolving, and some are held together by ambition and a concerning number of terminal tabs."
  />

  <section class="projects-hero surface-panel">
    <div>
      <p class="eyebrow">operating thesis</p>
      <h2>build tools that make complex systems easier to model, monitor, or explain.</h2>
    </div>

    <p>
      the projects here connect computational aerospace work with practical systems engineering:
      simulation tools, infrastructure, automation, monitoring, and workflow design.
    </p>
  </section>

  <section class="featured-projects">
    {featuredProjects.map((project, index) => (
      <article class="project-card surface-panel">
        <div class="project-number">
          {String(index + 1).padStart(2, "0")}
        </div>

        <div class="project-content">
          <div class="project-topline">
            <p class="eyebrow">{project.eyebrow}</p>
            <span>{project.status}</span>
          </div>

          <h2>{project.title}</h2>
          <p>{project.description}</p>

          <ul class="project-stack" aria-label={`${project.title} stack`}>
            {project.stack.map((item) => (
              <li>{item}</li>
            ))}
          </ul>

          <a class="text-link" href={project.href}>
            view project →
          </a>
        </div>
      </article>
    ))}
  </section>

  <section class="project-lab">
    <div class="section-heading">
      <p class="eyebrow">lab bench</p>
      <h2>smaller experiments</h2>
    </div>

    <div class="mini-project-grid">
      {smallerProjects.map((project) => (
        <article class="mini-project surface-panel">
          <p class="eyebrow">{project.label}</p>
          <h3>{project.title}</h3>
          <p>{project.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="surface-panel project-note">
    <p class="eyebrow">project philosophy</p>
    <h2>not everything needs to be finished to be worth showing.</h2>
    <p>
      the point of this page is to show direction, taste, technical growth, and the ability
      to turn vague ideas into working systems. finished products are nice. documented,
      evolving systems are often more honest.
    </p>
  </section>
</BaseLayout>

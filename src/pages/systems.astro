---
import BaseLayout from "../layouts/base.astro";
import PageIntro from "../components/page-intro.astro";

const services = [
  {
    name: "public website",
    status: "online",
    detail: "Astro site deployed through Cloudflare.",
  },
  {
    name: "status monitoring",
    status: "online",
    detail: "Uptime Kuma public status board for internet-facing checks.",
  },
  {
    name: "minecraft infrastructure",
    status: "private",
    detail: "Game server operations, backup workflows, and admin tooling stay behind access controls.",
  },
  {
    name: "homelab node",
    status: "private",
    detail: "Host telemetry, container details, and internal metrics are intentionally not public.",
  },
];

const layers = [
  {
    title: "edge and access",
    detail: "Cloudflare DNS, Pages deploys, tunnels, and policy gates for private surfaces.",
  },
  {
    title: "observability",
    detail: "Status checks, alerting, incident visibility, and enough telemetry to debug without oversharing.",
  },
  {
    title: "service operations",
    detail: "Linux services, containerized workloads, backups, update habits, and recovery notes.",
  },
];
---

<BaseLayout
  title="systems · colin vargas"
  description="Public systems status and infrastructure notes for urmom.systems."
  active="systems"
>
  <PageIntro
    eyebrow="systems / public status"
    title="operational status, minus the private parts."
    description="A public view of the urmom.systems stack: website health, monitoring, service operations, and the boundary between useful status and private telemetry."
  />

  <section class="systems-overview">
    {services.map((service) => (
      <article class="system-card surface-panel">
        <div class="system-card-topline">
          <h2>{service.name}</h2>
          <span class:list={["status-pill", service.status]}>{service.status}</span>
        </div>
        <p>{service.detail}</p>
      </article>
    ))}
  </section>

  <section class="systems-split">
    <div class="surface-panel status-board">
      <div class="status-board-header">
        <div>
          <p class="eyebrow">live status</p>
          <h2>uptime kuma public board</h2>
        </div>
        <a class="button ghost" href="https://status.urmom.systems">open status</a>
      </div>

      <iframe
        src="https://status.urmom.systems"
        loading="lazy"
        title="urmom.systems public status"
      />
    </div>

    <aside class="systems-layers">
      <p class="eyebrow">infrastructure layers</p>
      {layers.map((layer) => (
        <article>
          <h3>{layer.title}</h3>
          <p>{layer.detail}</p>
        </article>
      ))}
    </aside>
  </section>
</BaseLayout>
